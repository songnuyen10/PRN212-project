<Window x:Class="RestaurantPOS.WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RestaurantPOS.WpfApp.ViewModels"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="Restaurant POS" Height="500" Width="820"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Bàn ăn" Name="MnuTableMap" Click="MnuTableMap_Click"
                      Visibility="{Binding CanSeeTableMap, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <MenuItem Header="Ca làm việc" Name="MnuShift" Click="MnuShift_Click"
                      Visibility="{Binding CanSeeShift, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <MenuItem Header="Bếp" Name="MnuKitchen" Click="MnuKitchen_Click"
                      Visibility="{Binding CanSeeKitchen, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <MenuItem Header="Thực đơn" Name="MnuMenu" Click="MnuMenu_Click"
                      Visibility="{Binding CanSeeMenu, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <MenuItem Header="Kho nguyên liệu" Name="MnuInventory" Click="MnuInventory_Click"
                      Visibility="{Binding CanSeeInventory, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <MenuItem Header="Báo cáo" Name="MnuDashboard" Click="MnuDashboard_Click"
                      Visibility="{Binding CanSeeDashboard, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </Menu>

        <Grid>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="{Binding WelcomeText}" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="Chọn một chức năng ở menu phía trên." Foreground="Gray" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
