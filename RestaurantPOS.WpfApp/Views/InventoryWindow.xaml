<Window x:Class="RestaurantPOS.WpfApp.Views.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RestaurantPOS.WpfApp.ViewModels"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="Kho nguyên liệu" Height="520" Width="720"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:InventoryViewModel />
    </Window.DataContext>
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="240" />
        </Grid.ColumnDefinitions>

        <DataGrid Grid.Column="0" ItemsSource="{Binding Ingredients}" SelectedItem="{Binding SelectedIngredient}"
                  AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,16,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tên" Binding="{Binding IngredientName}" Width="*" />
                <DataGridTextColumn Header="Tồn kho" Binding="{Binding QuantityInStock}" Width="90" />
                <DataGridTextColumn Header="Đơn vị" Binding="{Binding Unit}" Width="70" />
                <DataGridTextColumn Header="Ngưỡng cảnh báo" Binding="{Binding LowStockThreshold}" Width="120" />
                <DataGridCheckBoxColumn Header="Sắp hết" Binding="{Binding IsLowStock}" Width="70" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Column="1">
            <TextBlock Text="Tên nguyên liệu" />
            <TextBox Text="{Binding InputName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
            <TextBlock Text="Đơn vị" />
            <TextBox Text="{Binding InputUnit, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
            <TextBlock Text="Số lượng tồn kho" />
            <TextBox Text="{Binding InputQuantity, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
            <TextBlock Text="Ngưỡng cảnh báo" />
            <TextBox Text="{Binding InputThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" />

            <Button Content="Thêm" Command="{Binding AddCommand}" Margin="0,0,0,8" Style="{StaticResource MaterialDesignRaisedButton}" />
            <Button Content="Cập nhật" Command="{Binding UpdateCommand}" Margin="0,0,0,8" />
            <Button Content="Xóa" Command="{Binding DeleteCommand}" Margin="0,0,0,8" />
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>
