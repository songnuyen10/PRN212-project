<Window x:Class="RestaurantPOS.WpfApp.Views.MenuManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RestaurantPOS.WpfApp.ViewModels"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="Quản lý thực đơn" Height="560" Width="900"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MenuManagementViewModel />
    </Window.DataContext>
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>

        <!-- Categories -->
        <DockPanel Grid.Column="0">
            <TextBlock DockPanel.Dock="Top" Text="Danh mục" FontWeight="Bold" Margin="0,0,0,8" />
            <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                <TextBox Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <Button Content="Thêm danh mục" Command="{Binding AddCategoryCommand}" Margin="0,0,0,4" />
                <Button Content="Xóa danh mục" Command="{Binding DeleteCategoryCommand}" />
            </StackPanel>
            <ListBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="CategoryName" />
        </DockPanel>

        <!-- Menu items -->
        <DataGrid Grid.Column="2" ItemsSource="{Binding MenuItems}" SelectedItem="{Binding SelectedMenuItem}"
                  AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Món" Binding="{Binding ItemName}" Width="*" />
                <DataGridTextColumn Header="Danh mục" Binding="{Binding MenuCategory.CategoryName}" Width="140" />
                <DataGridTextColumn Header="Giá" Binding="{Binding Price, StringFormat=N0}" Width="100" />
                <DataGridCheckBoxColumn Header="Đang bán" Binding="{Binding IsAvailable}" Width="70" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Column="3" Margin="16,0,0,0">
            <TextBlock Text="Tên món" />
            <TextBox Text="{Binding InputItemName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
            <TextBlock Text="Giá" />
            <TextBox Text="{Binding InputPrice, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
            <TextBlock Text="Danh mục" />
            <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding InputCategory}"
                      DisplayMemberPath="CategoryName" Margin="0,0,0,16" />

            <Button Content="Thêm món" Command="{Binding AddMenuItemCommand}" Margin="0,0,0,8" Style="{StaticResource MaterialDesignRaisedButton}" />
            <Button Content="Cập nhật" Command="{Binding UpdateMenuItemCommand}" Margin="0,0,0,8" />
            <Button Content="Xóa" Command="{Binding DeleteMenuItemCommand}" />
        </StackPanel>
    </Grid>
</Window>
