<Window x:Class="RestaurantPOS.WpfApp.Views.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="Thanh toán" Height="360" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="24">
        <StackPanel Visibility="{Binding IsPaid, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <TextBlock Text="Thanh toán đơn hàng" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />
            <TextBlock Text="{Binding CurrentOrder.Total, StringFormat='Tổng cộng: {0:N0} đ'}" FontSize="16" Margin="0,0,0,16" />

            <TextBlock Text="Hình thức thanh toán:" Margin="0,0,0,8" />
            <RadioButton Content="Tiền mặt" IsChecked="{Binding SelectedMethod, ConverterParameter=Cash, Converter={StaticResource EnumToBooleanConverter}}" Margin="0,0,0,4" />
            <RadioButton Content="Chuyển khoản" IsChecked="{Binding SelectedMethod, ConverterParameter=BankTransfer, Converter={StaticResource EnumToBooleanConverter}}" Margin="0,0,0,16" />

            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,8" />

            <Button Content="Xác nhận thanh toán" Click="Confirm_Click" Style="{StaticResource MaterialDesignRaisedButton}" />
        </StackPanel>

        <StackPanel Visibility="{Binding IsPaid, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="Thanh toán thành công!" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,8" />
            <Button Content="In hóa đơn" Click="Print_Click" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,0,8" />
            <Button Content="Đóng" Click="Close_Click" Style="{StaticResource MaterialDesignRaisedButton}" />
        </StackPanel>
    </StackPanel>
</Window>
