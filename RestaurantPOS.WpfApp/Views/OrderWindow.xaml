<Window x:Class="RestaurantPOS.WpfApp.Views.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="Order" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="40*" />
        </Grid.ColumnDefinitions>

        <!-- Menu (60%) -->
        <DockPanel Grid.Column="0">
            <TextBlock DockPanel.Dock="Top" Text="Thực đơn" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="SL:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="TxtQuantity" Width="50" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="Thêm vào giỏ" Command="{Binding AddToCartCommand}" Margin="16,0,0,0"
                        Style="{StaticResource MaterialDesignRaisedButton}" />
            </StackPanel>
            <ListBox ItemsSource="{Binding AvailableMenuItems}" SelectedItem="{Binding SelectedMenuItem}"
                     DisplayMemberPath="ItemName" />
        </DockPanel>

        <!-- Cart (40%) -->
        <DockPanel Grid.Column="2">
            <TextBlock DockPanel.Dock="Top" Text="Đơn hàng" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />

            <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                <TextBlock Text="{Binding SentTotal, StringFormat='Đã gửi bếp: {0:N0} đ'}" FontWeight="Bold" />
                <TextBlock Text="{Binding DraftTotal, StringFormat='Chưa gửi: {0:N0} đ'}" Margin="0,4,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,8" />
                <Button Content="Gửi bếp" Command="{Binding SendToKitchenCommand}" Margin="0,0,0,8"
                        Style="{StaticResource MaterialDesignRaisedButton}" />
                <Button Content="Chờ thanh toán" Command="{Binding MarkAwaitingPaymentCommand}" Margin="0,0,0,8" />
                <Button Content="Thanh toán" Click="Checkout_Click" Style="{StaticResource MaterialDesignRaisedButton}" />
            </StackPanel>

            <TextBlock DockPanel.Dock="Top" Text="Đã gửi bếp:" FontWeight="Bold" Margin="0,8,0,4" />
            <ListBox DockPanel.Dock="Top" ItemsSource="{Binding SentItems}" MaxHeight="180" IsEnabled="False" Opacity="0.6">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} x{1} — {2}">
                                    <Binding Path="MenuItem.ItemName" />
                                    <Binding Path="Quantity" />
                                    <Binding Path="Status" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Text="Giỏ hàng (chưa gửi):" FontWeight="Bold" Margin="0,12,0,4" />
            <ListBox ItemsSource="{Binding DraftLines}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} x{1}">
                                        <Binding Path="MenuItem.ItemName" />
                                        <Binding Path="Quantity" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <Button Grid.Column="1" Content="Xóa"
                                    Command="{Binding DataContext.RemoveDraftLineCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</Window>
